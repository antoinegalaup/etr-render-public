## Remote WordPress export settings (for scripts/*.sh)
#
# SSH target used by ssh/scp, e.g. ubuntu@myhost or user@server
WP_SSH=user@server
#
# Optional SSH port (WordPress.com Business often uses port 22, but keep configurable)
WP_SSH_PORT=22
#
# Absolute path to WordPress install on the server (folder containing wp-config.php)
WP_PATH=/var/www/html

# Optional staging target for direct plugin/theme sync deployments
STAGING_WP_SSH=
STAGING_WP_SSH_PORT=22
STAGING_WP_PATH=
STAGING_REMOTE_BACKUPS_DIR=
#
# Local folder (in this repo) where exports will be copied
EXPORTS_DIR=./exports
#
# Local folder for full backups (DB + wp-content archives)
BACKUPS_DIR=./backups
#
# Writable folder on remote host for backup artifacts
REMOTE_BACKUPS_DIR=/home/USER/exports
#
# Manifest metadata
SITE_NAME=example.com
SITE_URL=https://example.com
SITE_ENV=production

## Database transfer (WordPress MySQL -> Postgres/Supabase)
# Source MySQL
DB_TRANSFER_SOURCE_HOST=127.0.0.1
DB_TRANSFER_SOURCE_PORT=3307
DB_TRANSFER_SOURCE_USER=wp
DB_TRANSFER_SOURCE_PASSWORD=wp
DB_TRANSFER_SOURCE_DATABASE=wp
DB_TRANSFER_SOURCE_PREFIX=wp_
# Set true to transfer every wp_* table (full WordPress mirror mode)
DB_TRANSFER_SOURCE_ALL=false
# Optional include/exclude table filters (comma-separated glob or /regex/flags)
DB_TRANSFER_SOURCE_INCLUDE=
DB_TRANSFER_SOURCE_EXCLUDE=
# Optional comma-separated list, e.g. vikbooking_orders,vikbooking_customers
DB_TRANSFER_SOURCE_TABLES=
# Target Postgres/Supabase (local Supabase default)
DB_TRANSFER_TARGET_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?sslmode=disable
DB_TRANSFER_TARGET_SCHEMA=public
# Optional overrides. Defaults depend on mode:
# - default VikBooking mode: vb_raw_rows / vb_sync_state
# - --source-all mode:       wp_raw_rows / wp_sync_state
DB_TRANSFER_TARGET_RAW_TABLE=
DB_TRANSFER_TARGET_STATE_TABLE=
DB_TRANSFER_BATCH_SIZE=500

## Local clone + Dev Hub WordPress admin bootstrap
# Local MySQL credentials used by Dev Hub to discover admin username in wp_users
LOCAL_WP_DB_HOST=127.0.0.1
LOCAL_WP_DB_PORT=3307
LOCAL_WP_DB_USER=wp
LOCAL_WP_DB_PASSWORD=replace-with-local-db-password
LOCAL_WP_DB_NAME=wp
LOCAL_WP_TABLE_PREFIX=wp_
# Required: password assigned to imported local WordPress users
LOCAL_ADMIN_PASSWORD=replace-with-local-admin-password
# Optional: comma-separated source URLs/domains to force rewrite to LOCAL_SITE_URL during clone import.
# Example: LOCAL_FORCE_SOURCE_URLS=https://example.com,https://www.example.com
LOCAL_FORCE_SOURCE_URLS=

## Realtime sync ingest server (Supabase projection API)
SYNC_INGEST_ENABLED=false
SYNC_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?sslmode=disable
SYNC_SCHEMA=sync
# Required when SYNC_INGEST_ENABLED=true
SYNC_HMAC_SECRET=replace-with-strong-shared-secret
SYNC_MAX_CLOCK_SKEW_SECONDS=300

## Website-authoritative control plane
# Base URL for the source-of-truth WordPress/VikBooking site
WORDPRESS_BASE_URL=https://example.com
# Hosted Supabase is the canonical platform layer for this stack:
# - Postgres system of record
# - Supabase Auth for staff identity
# - Realtime backbone
# Render or other compute hosts should run API/workers only.
# Hosted Supabase URL + anon key used by the staff API to create and validate staff sessions
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
# Optional but recommended when server-side admin operations will use Supabase APIs directly
SUPABASE_SERVICE_ROLE_KEY=
# Optional staff access controls for the protected mobile/staff API
STAFF_ALLOWED_EMAILS=
STAFF_ALLOWED_EMAIL_DOMAINS=
STAFF_AUTH_RELAXED=false
# Guest portal session signing secret used by the Next.js frontend
PORTAL_SESSION_SECRET=replace-with-strong-shared-secret
# Shared secret for server-to-server internal API routes.
# If unset, the API falls back to PORTAL_SESSION_SECRET.
INTERNAL_API_SECRET=
# Expose /architecture* routes publicly only when explicitly enabled.
EXPOSE_ARCHITECTURE_ROUTES=false
# Public abuse controls for anonymous guest endpoints.
PUBLIC_RATE_LIMIT_ENABLED=true
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_PROPERTIES_MAX=120
PUBLIC_RATE_LIMIT_AVAILABILITY_MAX=60
PUBLIC_RATE_LIMIT_QUOTES_MAX=20
PUBLIC_RATE_LIMIT_CHECKOUT_MAX=20
PUBLIC_RATE_LIMIT_CHAT_MAX=12
PUBLIC_RATE_LIMIT_PORTAL_MAX=10
# Optional override if the commands endpoint is mounted elsewhere
WORDPRESS_COMMAND_ENDPOINT=/wp-json/wpshell-sync/v1/commands
# Shared HMAC secret used for signed command calls back to WordPress
WORDPRESS_COMMAND_SECRET=replace-with-strong-shared-secret

## Off-site channel redirects
CHANNEL_SUCCESS_URL=https://your-channel.example.com/booking/success
CHANNEL_CANCEL_URL=https://your-channel.example.com/booking/cancel

## Stripe platform-first rail
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Existing ETR connected account under your platform Stripe account
STRIPE_ETR_CONNECTED_ACCOUNT=

## Crypto rail (NOWPayments-compatible defaults)
CRYPTO_API_BASE_URL=https://api.nowpayments.io/v1
CRYPTO_API_KEY=
CRYPTO_WEBHOOK_SECRET=

## Dev Hub: Agent Sessions + Supabase Push Sync
# VikBooking admin path (inside wp-admin) loaded in the dedicated VikBooking iframe.
VIKBOOKING_ADMIN_PATH=/wp-admin/admin.php?page=vikbooking
# Local path to the VikBooking plugin used for context scans (local-only; keep ignored by git).
VIKBOOKING_PLUGIN_PATH=./wp-content/plugins/vikbooking

# Local Supabase Postgres (default matches `supabase start`)
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?sslmode=disable

# Hosted Supabase canonical (production source of truth)
# Use SSL for hosted URLs (sslmode=require).
DEVHUB_CANONICAL_MODE=true
DEVHUB_CANONICAL_SUPABASE_DB_URL=
DEVHUB_TARGET_SUPABASE_PROJECT_REF=ogeiuwonfbotfkbwolji

# Optional management access for hosted Supabase operations
DEVHUB_REMOTE_SUPABASE_DB_URL=
SUPABASE_ACCESS_TOKEN=

# Security and backup posture signals (used by /api/security/posture/status)
DEVHUB_PG_ENCRYPTION_KEY=
DEVHUB_ALLOW_LOCAL_SYNC_DEBUG=false
DEVHUB_BACKUP_PITR_ENABLED=true
DEVHUB_BACKUP_DAILY_SNAPSHOTS=true
DEVHUB_BACKUP_LAST_RESTORE_AT=

# Merge safeguards + UX
DEVHUB_MERGE_REQUIRE_BACKUP=true
DEVHUB_MERGE_DRYRUN_TTL_MIN=60
DEVHUB_FIGMA_EMBED_URL=

# Optional: if your CLIs use env-var auth
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Codex runtime used by OpenAI API agents (file-aware execution path).
# Preferred model; when unset Dev Hub tries gpt-5.3-codex then falls back to gpt-5.2-codex.
DEVHUB_CODEX_MODEL=
# Sandbox: read-only | workspace-write | danger-full-access
# Use danger-full-access for full file read/write/search from agents.
DEVHUB_CODEX_SANDBOX=danger-full-access

# Local port override to avoid clashing with other dashboards that use 3000.
WRAPPER_API_HOST_PORT=3001
WRAPPER_API_PUBLIC_BASE_URL=http://127.0.0.1:3001

## Background workers
WORKER_DATABASE_URL=
WORKER_VIKBOOKING_SYNC_ENABLED=false
WORKER_VIKBOOKING_SYNC_INTERVAL_MS=300000
WORKER_COMMAND_QUEUE_ENABLED=false
WORKER_COMMAND_QUEUE_INTERVAL_MS=15000
WORKER_RECONCILIATION_ENABLED=false
WORKER_RECONCILIATION_INTERVAL_MS=60000
